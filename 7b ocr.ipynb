# ============================================
# Step 2: Import Libraries
# ============================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

from ucimlrepo import fetch_ucirepo

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder, StandardScaler

from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense
from tensorflow.keras.utils import to_categorical

# ============================================
# Step 3: Fetch OCR Letter Recognition Dataset
# ============================================

letter_recognition = fetch_ucirepo(id=59)

# Features and Target
X = letter_recognition.data.features
y = letter_recognition.data.targets

# Display dataset info
print("First 5 Rows:")
print(X.head())

print("\nTarget Values:")
print(y.head())

# ============================================
# Step 4: Encode Target Labels
# ============================================

# Convert dataframe column into array
y = y.values.ravel()

# Convert letters A-Z into numbers 0-25
encoder = LabelEncoder()
y_encoded = encoder.fit_transform(y)

# One-hot encoding
y_categorical = to_categorical(y_encoded)

print("\nEncoded Shape:", y_categorical.shape)

# ============================================
# Step 5: Train-Test Split
# ============================================

X_train, X_test, y_train, y_test = train_test_split(
    X,
    y_categorical,
    test_size=0.2,
    random_state=42
)

# ============================================
# Step 6: Feature Scaling
# ============================================

scaler = StandardScaler()

X_train = scaler.fit_transform(X_train)
X_test = scaler.transform(X_test)

# ============================================
# Step 7: Build Deep Neural Network
# ============================================

model = Sequential()

# Hidden Layer 1
model.add(Dense(128, activation='relu', input_shape=(X_train.shape[1],)))

# Hidden Layer 2
model.add(Dense(64, activation='relu'))

# Output Layer (26 classes)
model.add(Dense(26, activation='softmax'))

# ============================================
# Step 8: Compile Model
# ============================================

model.compile(
    optimizer='adam',
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

# Display Model Summary
model.summary()

# ============================================
# Step 9: Train Model
# ============================================

history = model.fit(
    X_train,
    y_train,
    epochs=30,
    batch_size=32,
    validation_split=0.2,
    verbose=1
)

# ============================================
# Step 10: Evaluate Model
# ============================================

loss, accuracy = model.evaluate(X_test, y_test)

print("\nTest Loss:", loss)
print("Test Accuracy:", accuracy)

# ============================================
# Step 11: Predictions
# ============================================

predictions = model.predict(X_test)

predicted_classes = np.argmax(predictions, axis=1)
actual_classes = np.argmax(y_test, axis=1)

# Display first 10 predictions
print("\nSample Predictions:\n")

for i in range(10):

    predicted_letter = encoder.inverse_transform(
        [predicted_classes[i]]
    )[0]

    actual_letter = encoder.inverse_transform(
        [actual_classes[i]]
    )[0]

    print(f"Actual: {actual_letter} | Predicted: {predicted_letter}")

# ============================================
# Step 12: Plot Accuracy Graph
# ============================================

plt.plot(history.history['accuracy'], label='Training Accuracy')
plt.plot(history.history['val_accuracy'], label='Validation Accuracy')

plt.title("Accuracy Graph")
plt.xlabel("Epochs")
plt.ylabel("Accuracy")
plt.legend()
plt.show()

# ============================================
# Step 13: Plot Loss Graph
# ============================================

plt.plot(history.history['loss'], label='Training Loss')
plt.plot(history.history['val_loss'], label='Validation Loss')

plt.title("Loss Graph")
plt.xlabel("Epochs")
plt.ylabel("Loss")
plt.legend()
plt.show()